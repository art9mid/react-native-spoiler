{
	"name": "react-native-spoiler",
	"version": "0.0.1",
	"description": "Spoiler effect for React Native — hide text, photos or any view behind an animated particle cloud",
	"main": "./lib/commonjs/index.js",
	"module": "./lib/module/index.js",
	"types": "./lib/typescript/index.d.ts",
	"react-native": "src/index",
	"source": "src/index",
	"workspaces": [
		"example"
	],
	"files": [
		"src",
		"react-native.config.js",
		"lib",
		"nitrogen",
		"android/build.gradle",
		"android/gradle.properties",
		"android/fix-prefab.gradle",
		"android/CMakeLists.txt",
		"android/src",
		"ios/**/*.h",
		"ios/**/*.m",
		"ios/**/*.mm",
		"ios/**/*.cpp",
		"ios/**/*.swift",
		"ios/Assets.xcassets",
		"nitro.json",
		"*.podspec",
		"README.md"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf android/build node_modules/**/android/build lib tsconfig.tsbuildinfo",
		"lint": "eslint \"**/*.{js,ts,tsx}\" --fix",
		"build": "bun run typecheck && bob build",
		"specs": "nitrogen --logLevel=\"debug\""
	},
	"keywords": [
		"react-native",
		"nitro",
		"spoiler",
		"particles",
		"hidden",
		"reveal"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/art9mid/react-native-spoiler.git"
	},
	"author": "Artem Pyvovar (https://github.com/art9mid)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/art9mid/react-native-spoiler/issues"
	},
	"homepage": "https://github.com/art9mid/react-native-spoiler#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"devDependencies": {
		"@react-native/eslint-config": "0.82.0",
		"@types/bun": "^1.3.4",
		"@types/react": "^19.2.17",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.5.6",
		"nitrogen": "^0.35.9",
		"prettier": "^3.8.4",
		"react": "19.1.1",
		"react-native": "0.82.1",
		"react-native-builder-bob": "^0.42.1",
		"react-native-ease": "^0.7.3",
		"react-native-nitro-modules": "^0.35.9",
		"typescript": "^5.8.3"
	},
	"peerDependencies": {
		"react": "*",
		"react-native": "*",
		"react-native-ease": ">=0.7.0",
		"react-native-nitro-modules": ">=0.35.0"
	},
	"eslintConfig": {
		"root": true,
		"extends": [
			"@react-native",
			"prettier"
		],
		"plugins": [
			"prettier"
		],
		"rules": {
			"prettier/prettier": [
				"warn",
				{
					"quoteProps": "consistent",
					"singleQuote": true,
					"tabWidth": 2,
					"trailingComma": "es5",
					"semi": false,
					"useTabs": false
				}
			]
		}
	},
	"eslintIgnore": [
		"node_modules/",
		"lib/"
	],
	"prettier": {
		"quoteProps": "consistent",
		"singleQuote": true,
		"tabWidth": 2,
		"trailingComma": "es5",
		"useTabs": false,
		"semi": false
	},
	"react-native-builder-bob": {
		"source": "src",
		"output": "lib",
		"targets": [
			"commonjs",
			"module",
			[
				"typescript",
				{
					"project": "tsconfig.json"
				}
			]
		]
	}
}
