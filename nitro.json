{
	"$schema": "https://nitro.margelo.com/nitro.schema.json",
	"cxxNamespace": [
		"spoiler"
	],
	"ios": {
		"iosModuleName": "NitroSpoiler"
	},
	"android": {
		"androidNamespace": [
			"spoiler"
		],
		"androidCxxLibName": "NitroSpoiler"
	},
	"autolinking": {
		"NitroSpoiler": {
			"swift": "HybridNitroSpoiler",
			"kotlin": "HybridNitroSpoiler"
		}
	},
	"ignorePaths": [
		"**/node_modules"
	]
}
